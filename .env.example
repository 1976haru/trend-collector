# ─────────────────────────────────────────────
# Trend Collector — 환경변수 예시 파일
# 실제 값은 .env 파일에 작성하세요. (.env 는 git 에 커밋되지 않습니다)
# Vite 에서 클라이언트로 노출되려면 변수 이름이 반드시 VITE_ 로 시작해야 합니다.
# ─────────────────────────────────────────────

# GitHub Pages 배포 경로 (저장소 이름과 일치) — 예: /trend-collector/
VITE_BASE_PATH=/trend-collector/

# RSS / CORS 프록시 (기본값: api.allorigins.win)
VITE_RSS_PROXY=https://api.allorigins.win/get?url=

# Google News RSS 검색 베이스
VITE_GOOGLE_NEWS_BASE=https://news.google.com/rss/search?hl=ko&gl=KR&ceid=KR:ko&q=

# ── 이메일 (EmailJS) ─────────────────────────
# https://www.emailjs.com 에서 무료 계정 생성 후 발급 (월 200건 무료)
# 이 값들은 클라이언트에 노출되므로 EmailJS 가 의도한 "공개키" 만 입력하세요.
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=

# ── Kakao SDK ────────────────────────────────
# https://developers.kakao.com 에서 무료 발급되는 JavaScript 앱 키
VITE_KAKAO_JS_KEY=

# ── (선택) Claude / Anthropic API 감성 분석 ──
# 클라이언트에서 직접 호출하면 키가 노출되므로,
# 실제 운영 시에는 별도 백엔드 프록시를 두는 것을 권장합니다.
# VITE_ANTHROPIC_API_KEY=
