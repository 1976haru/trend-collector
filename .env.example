# ─────────────────────────────────────────────
# Trend Collector — 환경변수 예시
# 실제 값은 .env 파일에 작성하세요 (.env 는 git 에 커밋되지 않습니다).
# Render 운영 시에는 Dashboard → Environment 에 동일한 값을 입력하세요.
# ─────────────────────────────────────────────

# ── 직원 공용 접근 비밀번호 (필수) ───────────
# 로그인 화면에서 입력하는 단일 비밀번호.
# 이 값을 변경하면 기존 세션은 모두 자동으로 무효화됩니다.
ADMIN_PASSWORD=change-me-please

# ── SMTP (메일 발송) ──────────────────────────
# 예: 네이버 SMTP — smtp.naver.com / 465 (secure) 또는 587 (STARTTLS)
# 예: Gmail 앱비밀번호 — smtp.gmail.com / 465 / 앱비밀번호 사용
SMTP_HOST=smtp.naver.com
SMTP_PORT=587
SMTP_USER=username@naver.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Trend Collector <username@naver.com>"

# ── 일일 자동 수집 시각 (Asia/Seoul, HH:MM) ──
REPORT_TIME=09:00

# ── 메일 본문에 임베드할 서비스 절대 URL ─────
# 예: https://trend-collector.onrender.com
BASE_URL=http://localhost:3000

# ── 기능 개선 제안 메일 수신 (관리자) ────────
# 사용자가 “기능 개선 제안하기” 모달로 제출하면 이 주소로 메일이 발송됩니다.
FEEDBACK_TO_EMAIL=admin@example.go.kr

# ── (선택) LLM 요약 — 현재 MVP 미사용 ────────
# 추후 본문 자동 요약을 추가할 때 사용합니다.
OPENAI_API_KEY=

# ── 네이버 뉴스 검색 API ─────────────────────
# https://developers.naver.com 에서 애플리케이션 등록 → 검색 API 사용 신청.
# 일일 25,000건 무료. 세 변수 모두 있고 NAVER_ENABLED=true 이어야 활성.
NAVER_ENABLED=false
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── 카카오톡 알림 (스텁 — 기본 OFF) ──────────
# KAKAO_ENABLED=true 일 때만 실 발송 시도합니다.
# 실 운영 시에는 비즈니스 채널 알림톡(유료) 또는 사용자 인증 access_token 사용 권장.
KAKAO_ENABLED=false
KAKAO_ACCESS_TOKEN=
KAKAO_TEMPLATE_ID=
KAKAO_TARGET_UUID=

# ── 서버 포트 (Render 가 자동 주입) ──────────
# 로컬에서만 사용. Render 운영 환경은 PORT 가 자동 설정됩니다.
PORT=3000

# ── 데이터 저장 경로 (선택) ──────────────────
# 기본값: ./data  (Render Disk 사용 시 /var/data 등으로 변경)
# DATA_DIR=./data

# ── Puppeteer (선택) ─────────────────────────
# 시스템에 이미 Chrome 이 있다면 PUPPETEER_EXECUTABLE_PATH 로 지정 가능.
# Render 표준 환경에서는 puppeteer 가 자체 다운로드한 Chromium 을 사용합니다.
# PUPPETEER_EXECUTABLE_PATH=
